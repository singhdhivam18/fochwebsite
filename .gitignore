# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.so
*.egg-info/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/

# ── Django generated ──────────────────────────────────────────────────────────
staticfiles/       # populated by collectstatic — never commit generated output
db.sqlite3         # dev database — never commit
db.sqlite3-journal

# ── Secrets — NEVER commit any of these ──────────────────────────────────────
.env               # real environment variables (credentials live here)
.env.*             # any .env variant
!.env.example      # the template IS safe to commit
config.ini         # old credential file — replaced by .env, must stay out of git
*.pem
*.key

# ── Media / uploaded files ────────────────────────────────────────────────────
# Uploads belong only on the server bind-mounted volume (C:\deployments\media).
# The folder itself is tracked (via media/.gitkeep) but its contents are not.
media/*
!media/.gitkeep

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Backups / temp ────────────────────────────────────────────────────────────
*.bak
*.backup
backups/
*.swp
*.swo

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Node / frontend tooling ───────────────────────────────────────────────────
node_modules/

# ── Docker local overrides ────────────────────────────────────────────────────
docker-compose.override.yml
