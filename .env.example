# .env.example — copy to .env on the server and fill in real values.
# This file IS committed to GitHub (it contains no secrets).
# The real .env is in .gitignore and must NEVER be committed.

# ── Django ────────────────────────────────────────────────────────────────────
# Generate a real key: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=change-me-generate-a-real-key

# Set to False in production (already the default in settings.py)
DEBUG=False

# Comma-separated — add your server IP and domain
ALLOWED_HOSTS=SERVER_IP,yourdomain.com

# ── JWT (must match the variable name settings.py reads: JWT_SECRET_KEY) ──────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-real-jwt-secret

# ── Media storage (inside container — bind-mounted from C:\deployments\media) ──
MEDIA_ROOT=/app/media

# ── SQL Server (Step 12 — leave blank until database is ready) ────────────────
# DB_HOST: how the Django container reaches SQL Server on the Windows host.
#   host.docker.internal  →  resolves to the Windows VPS from inside Docker
#                            (works on Docker Desktop + WSL2 Docker Engine)
DB_HOST=host.docker.internal
DB_PORT=1433
DB_NAME=ssms_new
DB_USER=fochwebsite_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# The ODBC driver string must exactly match what is installed in the Docker image.
# The Dockerfile installs ODBC Driver 18 — do not change this unless you rebuild.
DB_DRIVER=ODBC Driver 18 for SQL Server
